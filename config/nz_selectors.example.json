{
  "login_url": "https://nz.ua/",
  "open_login_button_selector": "text=Увійти",
  "open_login_wait_ms": 1200,
  "login_selector": "#loginform-login",
  "password_selector": "#loginform-password",
  "submit_selector": "button[name=\"login-button\"]",
  "post_login_wait_ms": 7000,
  "auth_success_selectors": [
    "a:has-text(\"Вийти\")",
    "a[href*=\"/account\"]"
  ],
  "exports": [
    {
      "name": "attendance-week",
      "url": "https://nz.ua/reports/attendance/week",
      "download_button_selector": "button[data-action=\"export-csv\"]",
      "timeout_ms": 30000
    },
    {
      "name": "attendance-month",
      "url": "https://nz.ua/reports/attendance/month",
      "download_button_selector": "button[data-action=\"export-csv\"]",
      "timeout_ms": 30000
    },
    {
      "name": "attendance-semester",
      "url": "https://nz.ua/reports/attendance/semester",
      "download_button_selector": "button[data-action=\"export-csv\"]",
      "timeout_ms": 30000
    }
  ]
}
