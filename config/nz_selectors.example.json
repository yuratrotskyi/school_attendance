      "timeout_ms": 30000
    },
    {
      "name": "attendance-semester",
      "url": "https://nz.ua/reports/attendance/semester",
      "download_button_selector": "button[data-action=\"export-csv\"]",
      "timeout_ms": 30000
    }
  ]
